# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Get yours from: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/card-max?retryWrites=true&w=majority

# ─── Vercel ISR Revalidation ──────────────────────────────────────────────────
# A random secret used to protect the /api/revalidate endpoint.
# Generate one with: openssl rand -base64 32
# Must also be added as a GitHub Actions secret AND a Vercel env var.
VERCEL_REVALIDATION_SECRET=change-me-to-a-random-32-char-secret

# ─── App URL (used by crawler to call the revalidation endpoint) ──────────────
# Set to your production Vercel URL (no trailing slash)
VERCEL_APP_URL=https://card-max.vercel.app

# ─── Brandfetch Logo API (secondary fallback for merchant logos) ──────────────
# Free tier: 50 calls/month. Get your key at https://brandfetch.com
# Also add as a GitHub Actions secret: BRANDFETCH_API_KEY
BRANDFETCH_API_KEY=your-brandfetch-api-key-here
